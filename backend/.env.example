# ── Model ─────────────────────────────────────────────────────
# Pre-trained HuggingFace model ID.
# Options:
#   mrm8488/bert-tiny-finetuned-fake-news-detection   (tiny, fast, ~17 MB)
#   distilbert-base-uncased                            (requires your own weights)
MODEL_NAME=mrm8488/bert-tiny-finetuned-fake-news-detection

# Path to a local fine-tuned model (overrides MODEL_NAME if set)
# LOCAL_MODEL_PATH=./saved_model

# ── Server ────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Inference ─────────────────────────────────────────────────
MAX_INPUT_TOKENS=512
BATCH_SIZE_LIMIT=32
